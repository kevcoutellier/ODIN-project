      "esbuild",
      "protobufjs"
    ]
  },
  "license": "MIT",
  "author": "AgentLayers",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentlayers/odin"
  },
  "devDependencies": {
    "docx": "^9.6.1",
    "vitest": "^3.2.4"
  }
}
