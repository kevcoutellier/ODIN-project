{
  "name": "odin",
  "version": "0.1.0",
  "description": "Odin by AgentLayers — Zero Trust AI Agent, Secured by Design, Trusted by Network",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @odin/cli dev",
